#----DATASET manipulation----
#making new columns to differentiate the data by genotype and timepoint
DATASET$Genotype <- ifelse(grepl("E8|D5", DATASET$Image), "Mutant",
                    ifelse(grepl("NAS2S|NAS2M", DATASET$Image), "Control", NA))
DATASET$Timepoint <- ifelse(grepl("D120", DATASET$Image), "D120", "D90")

#factoring the dataset to the graph in a specific order
DATASET$GenotypeTime <- factor(paste(DATASET$Genotype, DATASET$Timepoint, sep = "_"),
                               levels = c("Control_D90", "Control_D120",
                                          "Mutant_D90", "Mutant_D120")

#Giving a colour to each batch
DATASET <- DATASET %>%
           mutate(Batch_Colour = case_when(
                  grepl("Cal1", base_name) ~ "Blue",
                  grepl("Ru1", base_name)  ~ "Yellow",
                  grepl("Ru2", base_name)  ~ "Red",
                  grepl("Ru3", base_name)  ~ "Green",
                  TRUE ~ NA_character_))
)

#----Plots----
boxplot(PositivePer ~ GenotypeTime,
          data = DATASET,
          main = "TITLE",
          xlab = "Genotype / Timepoint",
          ylab = "YAXIS"
)

stripchart(PositivePer ~ GenotypeTime,
           data = DATASET,
           vertical = TRUE,
           pch = 16,
           col = "black",
           add = TRUE
)
